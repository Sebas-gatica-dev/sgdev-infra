APP_SLUG=portfolio
APP_PATH=${portfolio_path}
APP_UPSTREAM=${portfolio_upstream}
APP_ROOT=${apps_root}/portfolio
REPO_DIR=${apps_root}/portfolio/repo
COMPOSE_FILES=docker-compose.yml /opt/sgdev-infra/examples/project-compose/portfolio.compose.proxy.override.yml
ENV_FILE=.env
BRANCH=${portfolio_branch}
GIT_REMOTE_URL=${portfolio_repo_url}
STRIP_PREFIX=false
CLIENT_MAX_BODY_SIZE=25m
PROXY_READ_TIMEOUT=300s
PROXY_SEND_TIMEOUT=300s
