vps_host = "143.95.217.87"
ssh_port = 22022
ssh_user = "root"
domain   = "sgdev.com.ar"

infra_repo_url = "https://github.com/Sebas-gatica-dev/sgdev-infra.git"
infra_branch   = "main"

# Enable when the portfolio repository has a deployable .env on the VPS.
configure_portfolio = false
portfolio_repo_url  = "https://github.com/Sebas-gatica-dev/sgdev-porfolio.git"
portfolio_branch    = "main"
portfolio_path      = "/portfolio"
portfolio_upstream  = "http://portfolio-nginx:80"

# Set secrets outside this file:
# export TF_VAR_ssh_private_key="$(cat ~/.ssh/sgdev_deploy)"
# or, only as a fallback:
# export TF_VAR_vps_password="..."
