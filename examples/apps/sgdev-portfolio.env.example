APP_SLUG=portfolio
APP_PATH=/portfolio
APP_UPSTREAM=http://host.docker.internal:18080

APP_ROOT=/opt/apps/portfolio
REPO_DIR=/opt/apps/portfolio/repo
COMPOSE_FILES=docker-compose.yml
ENV_FILE=.env
BRANCH=main
GIT_REMOTE_URL=

STRIP_PREFIX=false
CLIENT_MAX_BODY_SIZE=25m
PROXY_READ_TIMEOUT=300s

BACKUP_VOLUMES="sgdev_portfolio_postgres_data"
