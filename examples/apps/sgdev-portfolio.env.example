APP_SLUG=portfolio
APP_PATH=/portfolio
APP_UPSTREAM=http://portfolio-nginx:80

APP_ROOT=/opt/apps/portfolio
REPO_DIR=/opt/apps/portfolio/repo
COMPOSE_FILES="docker-compose.yml /opt/sgdev-infra/examples/project-compose/portfolio.compose.proxy.override.yml"
ENV_FILE=.env
BRANCH=main
GIT_REMOTE_URL=

STRIP_PREFIX=false
CLIENT_MAX_BODY_SIZE=25m
PROXY_READ_TIMEOUT=300s
REJECT_PUBLIC_PORTS=true

# Variables consumidas por docker compose durante el deploy.
# El deploy carga primero este archivo y luego el .env del repo, por lo que
# /opt/apps/portfolio/repo/.env puede sobrescribir secretos o valores runtime.
PUBLIC_APP_URL=https://sgdev.com.ar/portfolio
VITE_BASE_PATH=/portfolio/

PORTFOLIO_IP_PROMPT_LIMIT_ENABLED=true
PORTFOLIO_IP_TOKEN_LIMIT_MAX_TOKENS=200
PORTFOLIO_IP_TOKEN_LIMIT_CHAT_COST=10
PORTFOLIO_IP_TOKEN_LIMIT_VOICE_COST=10
PORTFOLIO_IP_PROMPT_LIMIT_VOICE_SESSION_SECONDS=120
PORTFOLIO_IP_TOKEN_LIMIT_MAX_VOICE_SECONDS=300
PORTFOLIO_APPOINTMENT_DEMO_CLEANUP_RETENTION_DAYS=2

# Debe coincidir con SGDEV_PORTFOLIO_USAGE_ADMIN_TOKEN en
# /etc/sgdev-infra/admin-control-api.env para acreditar tokens desde /admin.
PORTFOLIO_USAGE_ADMIN_TOKEN=change-me-admin-token
PORTFOLIO_ADMIN_TOKEN=change-me-admin-token
PORTFOLIO_PROJECT_MAX_IMAGE_BYTES=5242880

BACKUP_VOLUMES="repo_portfolio_postgres_data repo_portfolio_ollama_data repo_portfolio_project_media"

# Export/import Excel de datos del proyecto.
DB_EXCEL_ENGINE=postgres
DB_EXCEL_SERVICE=db
DB_EXCEL_DATABASE=portfolio
DB_EXCEL_USER=portfolio
DB_EXCEL_APP_ID_COLUMN=app_id
