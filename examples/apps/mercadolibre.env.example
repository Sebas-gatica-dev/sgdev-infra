APP_SLUG=mercadolibre
APP_NAME="SGDEV MercadoLibre API"
APP_ID=mercadolibre
APP_DOMAIN=sgdev.com.ar
APP_PATH=/mercadolibre
APP_UPSTREAM=http://mercadolibre-api:8080
APP_ROOT=/opt/apps/mercadolibre
REPO_DIR=/opt/sgdev-infra
COMPOSE_FILES=services/mercadolibre/compose.yml
ENV_FILE=/etc/sgdev-infra/mercadolibre.env
BRANCH=main
GIT_REMOTE_URL=
STRIP_PREFIX=true
CLIENT_MAX_BODY_SIZE=10m
PROXY_CONNECT_TIMEOUT=10s
PROXY_READ_TIMEOUT=120s
PROXY_SEND_TIMEOUT=120s
BACKUP_DIR=/opt/backups/mercadolibre

BACKUP_COMMAND=
BACKUP_VOLUMES=
BACKUP_PATHS=

DB_EXCEL_ENGINE=postgres
DB_EXCEL_SERVICE=db
DB_EXCEL_DATABASE=mercadolibre
DB_EXCEL_USER=mercadolibre
DB_EXCEL_APP_ID_COLUMN=
