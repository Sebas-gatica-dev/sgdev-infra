APP_SLUG=soff-portfolio
APP_NAME="Portfolio de Soff"
APP_ID=app_soff_portfolio
APP_PATH=/soff-portfolio
APP_UPSTREAM=http://soff-portfolio-web:3000

APP_ROOT=/opt/apps/soff-portfolio
REPO_DIR=/opt/apps/soff-portfolio/repo
COMPOSE_FILE=compose.sgdev.yml
ENV_FILE=.env
BRANCH=main
GIT_REMOTE_URL=https://github.com/Sebas-gatica-dev/porfolio-diseno.git

STRIP_PREFIX=false
CLIENT_MAX_BODY_SIZE=10m
PROXY_READ_TIMEOUT=120s
REJECT_PUBLIC_PORTS=true

NEXT_PUBLIC_BASE_PATH=/soff-portfolio

# Optional contact form configuration. Keep real values only in
# /etc/sgdev-infra/apps/soff-portfolio.env on the VPS.
# MAILTRAP_API_TOKEN=
# CONTACT_TO_EMAIL=
# MAIL_FROM_EMAIL=
# MAIL_FROM_NAME="Portfolio Sofia"
