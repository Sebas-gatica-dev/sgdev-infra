APP_SLUG=janoai
APP_PATH=/janoai
APP_UPSTREAM=http://janoai-nginx:80

APP_ROOT=/opt/apps/janoai
REPO_DIR=/opt/apps/janoai/repo
COMPOSE_FILE=compose.prod.yml
# Optional if you want to keep compose.prod.yml untouched:
# COMPOSE_FILES="compose.prod.yml /opt/sgdev-infra/examples/project-compose/janoai.compose.proxy.override.yml"
ENV_FILE=.env.production
BRANCH=main

# Optional. If the repo is missing, app-deploy.sh can clone it.
GIT_REMOTE_URL=

# true strips /janoai before forwarding to the inner project proxy.
STRIP_PREFIX=true

CLIENT_MAX_BODY_SIZE=25m
PROXY_READ_TIMEOUT=180s

# Use actual Docker volume names from `docker volume ls`.
BACKUP_VOLUMES="janoai_postgres_data janoai_redis_data"
