APP_SLUG=egregor
APP_PATH=/egregorai
APP_UPSTREAM=http://egregor-web:80

APP_ROOT=/opt/apps/egregorai
REPO_DIR=/opt/apps/egregorai/repo
COMPOSE_FILE=docker-compose.yml
# Optional if you want to keep docker-compose.yml untouched:
# COMPOSE_FILES="docker-compose.yml /opt/sgdev-infra/examples/project-compose/egregor.compose.proxy.override.yml"
ENV_FILE=.env
BRANCH=main
GIT_REMOTE_URL=

STRIP_PREFIX=true
CLIENT_MAX_BODY_SIZE=25m
PROXY_READ_TIMEOUT=240s

# Adjust names after the first `docker volume ls`.
BACKUP_VOLUMES="egregor_egregor_pgdata egregor_egregor_models"
