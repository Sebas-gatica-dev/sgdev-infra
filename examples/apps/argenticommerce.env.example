APP_SLUG=argenticommerce
APP_NAME=ArgentiCommerce
APP_ID=argenticommerce
APP_DOMAIN=sgdev.com.ar
APP_PATH=/argenticommerce
APP_UPSTREAM=http://argenticommerce-nginx:80
APP_ROOT=/opt/apps/argenticommerce
REPO_DIR=/opt/apps/argenticommerce/repo
COMPOSE_FILES=compose.sgdev.yml
ENV_FILE=.env.sgdev
BRANCH=main
GIT_REMOTE_URL=
STRIP_PREFIX=false
CLIENT_MAX_BODY_SIZE=25m
PROXY_CONNECT_TIMEOUT=10s
PROXY_READ_TIMEOUT=120s
PROXY_SEND_TIMEOUT=120s
BACKUP_DIR=/opt/backups/argenticommerce

BACKUP_COMMAND=
BACKUP_VOLUMES=
BACKUP_PATHS=

DB_EXCEL_ENGINE=postgres
DB_EXCEL_SERVICE=db
DB_EXCEL_DATABASE=argenticommerce
DB_EXCEL_USER=argenticommerce
DB_EXCEL_APP_ID_COLUMN=tenant_id
