COMPOSE_PROJECT_NAME=sgdev-mercadolibre
PROXY_NETWORK=sgdev-proxy
DATA_NETWORK=sgdev-data
SERVICE_NETWORK=sgdev-services

DATABASE_URL=postgresql://mercadolibre:change-me-mercadolibre@sgdev-postgres:5432/mercadolibre
DB_HOST=sgdev-postgres
DB_PORT=5432
DB_NAME=mercadolibre
DB_USER=mercadolibre
DB_PASSWORD=change-me-mercadolibre
SERVICE_TOKEN=change-me-shared-service-token

PUBLIC_BASE_URL=https://sgdev.com.ar/mercadolibre
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_NOTIFICATION_URL=https://sgdev.com.ar/mercadolibre/webhooks/mercadopago

MERCADOLIBRE_CLIENT_ID=
MERCADOLIBRE_CLIENT_SECRET=
MERCADOLIBRE_REDIRECT_URI=https://sgdev.com.ar/mercadolibre/v1/mercadolibre/oauth/callback
